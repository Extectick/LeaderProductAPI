# === Database ===
DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/LeaderAPI?schema=public
DB_PASSWORD=PASSWORD
DB_NAME=LeaderAPI

# === App ===
PORT=3000
DOMEN_URL=https://your-domain.com
ACCESS_TOKEN_SECRET=your_access_token_secret
REFRESH_TOKEN_SECRET=your_refresh_token_secret

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_BOT_USERNAME=YourBotUsername
# Optional: short name of Telegram Mini App (from BotFather /setdomain + /newapp)
TELEGRAM_MINI_APP_SHORT_NAME=your_mini_app_short_name
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret
TG_SESSION_SECRET=your_session_secret

# === SMTP (Mail.ru) ===
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USER=your-email@mail.ru
SMTP_PASS=your_smtp_password
SMTP_FROM=Your App <your-email@mail.ru>

# === S3 / MinIO ===
S3_ENDPOINT=http://localhost:9010
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=your_minio_secret
S3_BUCKET=leader-product-dev
FILES_BASE_URL=https://your-domain.com
FILES_REQUIRE_TOKEN=1
FILES_TOKEN_TTL=86400
FILE_TOKEN_SECRET=your_file_token_secret
FILES_CACHE_TTL=300
FILES_CACHE_MAX_BYTES=1048576

# === Redis ===
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=lp:
REDIS_CONNECT_TIMEOUT_MS=10000
# REDIS_DISABLE=1

# === Kafka ===
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=leader-api
KAFKA_REQUEST_TOPIC=api-requests
KAFKA_LOG_BODY=1
KAFKA_LOG_BODY_LIMIT=65536
KAFKA_BUFFER_MAX=1000

# === Debug ===
DEBUG_REQUESTS=1
# DEBUG_REQUESTS_KEEP=200
# DEBUG_RES_BODY_LIMIT=65536
# DEBUG_DASH_TOKEN=supersecret

# === Updates ===
UPDATE_PRESIGN_PUT_TTL=3600
UPDATE_UPLOAD_TIMEOUT_MS=1200000

# === Notifications (Scheduled Jobs) ===
# Часов до отправки напоминания о непрочитанных сообщениях
UNREAD_REMINDER_HOURS=4
# Часов до отправки напоминания о закрытии обращения
CLOSURE_REMINDER_HOURS=24
# Интервал опроса очереди задач в мс (по умолчанию 60000)
JOB_POLL_INTERVAL_MS=60000
# URL фронтенда для ссылок в Telegram-сообщениях (необязательно)
FRONTEND_URL=https://your-frontend.com
# 1 = не слать Telegram по NEW_MESSAGE, если пользователь online в приложении
# 0 = всегда слать Telegram по NEW_MESSAGE (как раньше)
TELEGRAM_SUPPRESS_ONLINE_NEW_MESSAGE=1
# Явный список типов, где Telegram не отправляется online-пользователю
# (приоритетнее TELEGRAM_SUPPRESS_ONLINE_NEW_MESSAGE)
TELEGRAM_SUPPRESS_ONLINE_TYPES=NEW_MESSAGE,STATUS_CHANGED,DEADLINE_CHANGED
# Интервал обновления online-ключа presence для активного socket-подключения
PRESENCE_REFRESH_MS=30000

# === 1C Integration ===
ONEC_SECRET=your_onec_secret
