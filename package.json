{
  "name": "server",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "cross-env NODE_ENV=development nodemon --watch src/**/*.ts --exec ts-node src/index.ts",
    "prisma": "prisma",
    "prisma:generate": "dotenv -e .env.dev -- prisma generate",
    "prisma:migrate": "dotenv -e .env.dev -- prisma migrate deploy",
    "studio": "node scripts/run-prisma-studio.js",
    "prisma:seed": "dotenv -e .env.dev -- ts-node --transpile-only src/prisma/seed.ts",
    "postinstall": "prisma generate",
    "test": "npm run test:unit",
    "test:unit": "cross-env NODE_ENV=test jest --config jest.unit.config.ts",
    "test:integration": "cross-env NODE_ENV=test TEST_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54329/LeaderAPI_test?schema=public TEST_REDIS_URL=redis://127.0.0.1:6389 jest --config jest.config.ts",
    "test:integration:db:up": "docker compose -p leaderproductapi-test -f docker-compose.test.yml up -d test-postgres test-redis test-minio",
    "test:integration:db:down": "docker compose -p leaderproductapi-test -f docker-compose.test.yml down -v",
    "test:integration:docker": "node scripts/run-integration-tests.js",
    "db:seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' src/prisma/seed.ts",
    "audit:employee-moderation": "node scripts/audit-employee-moderation-consistency.js",
    "fix:employee-moderation": "node scripts/fix-employee-moderation-consistency.js",
    "fix:employee-moderation:apply": "node scripts/fix-employee-moderation-consistency.js --apply"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@aws-sdk/client-s3": "^3.1068.0",
    "@aws-sdk/s3-request-presigner": "^3.1068.0",
    "@json2csv/plainjs": "^7.0.6",
    "@maxhub/max-bot-api": "^0.2.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/studio": "^0.511.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@tma.js/init-data-node": "^2.0.7",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "expo-server-sdk": "^6.1.0",
    "express": "^5.2.1",
    "fast-geoip": "^1.1.88",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "mime-types": "^3.0.2",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.0",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "redis": "^6.0.0",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "telegraf": "^4.16.3",
    "ua-parser-js": "^2.0.10",
    "validator": "^13.15.35",
    "write-excel-file": "^4.1.1",
    "zod": "^4.4.3",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/jest": "^30.0.0",
    "@types/json2csv": "^5.0.7",
    "@types/mime-types": "^3.0.1",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.3",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "glob": "13.0.6"
  }
}
