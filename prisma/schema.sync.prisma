// ==========================
// 1C Sync journal and meta
// ==========================

enum SyncDirection {
  IMPORT
  EXPORT
}

enum SyncStatus {
  STARTED
  COMPLETED
  PARTIAL
  FAILED
}

enum SyncItemStatus {
  OK
  ERROR
  SKIPPED
}

enum OnecSyncSessionStatus {
  STARTED
  ACCEPTING
  COMPLETING
  COMPLETED
  PARTIAL
  FAILED
}

enum OnecStageResolveStatus {
  PENDING
  RESOLVED
  BLOCKED
  ERROR
}

enum SyncEntityType {
  NOMENCLATURE
  ORGANIZATIONS
  WAREHOUSES
  COUNTERPARTIES
  AGREEMENTS
  PRODUCT_PRICES
  SPECIAL_PRICES
  STOCK
  ORDERS_EXPORT
  ORDERS_STATUS
  ORDERS_SNAPSHOT
}

model SyncRun {
  id           String        @id @default(cuid())
  requestId    String        @unique
  entity       SyncEntityType
  direction    SyncDirection
  status       SyncStatus    @default(STARTED)

  totalCount   Int           @default(0)
  successCount Int           @default(0)
  errorCount   Int           @default(0)

  startedAt    DateTime      @default(now())
  finishedAt   DateTime?
  notes        String?
  meta         Json?

  items        SyncRunItem[]

  @@index([entity, direction, startedAt])
  @@index([status, startedAt])
}

model SyncRunItem {
  id        String       @id @default(cuid())
  runId     String
  key       String
  status    SyncItemStatus
  error     String?
  payload   Json?
  createdAt DateTime     @default(now())

  run       SyncRun      @relation(fields: [runId], references: [id])

  @@index([runId])
  @@index([key])
  @@index([status])
}

model OnecSyncSession {
  id               String                @id @default(cuid())
  requestId        String                @unique
  status           OnecSyncSessionStatus @default(STARTED)
  replaceMode      Boolean               @default(false)
  selectedEntities Json?
  notes            String?

  acceptedCount    Int                   @default(0)
  resolvedCount    Int                   @default(0)
  blockedCount     Int                   @default(0)
  errorCount       Int                   @default(0)

  startedAt        DateTime              @default(now())
  completedAt      DateTime?
  lastActivityAt   DateTime              @default(now())

  nomenclatureItems  OnecStageNomenclature[]
  organizationItems  OnecStageOrganization[]
  warehouseItems     OnecStageWarehouse[]
  counterpartyItems  OnecStageCounterparty[]
  agreementItems     OnecStageAgreement[]
  productPriceItems  OnecStageProductPrice[]
  specialPriceItems  OnecStageSpecialPrice[]
  stockItems         OnecStageStock[]

  @@index([status, startedAt])
  @@index([lastActivityAt])
}

model OnecStageNomenclature {
  id               String                @id @default(cuid())
  sessionId        String
  sourceKey        String
  guid             String
  parentGuid       String?
  isGroup          Boolean
  payload          Json
  payloadHash      String
  sourceUpdatedAt  DateTime?
  lastImportedAt   DateTime              @default(now())
  resolveStatus    OnecStageResolveStatus @default(PENDING)
  lastResolveError String?
  resolvedAt       DateTime?

  session          OnecSyncSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, sourceKey])
  @@index([sessionId, resolveStatus])
  @@index([guid])
  @@index([parentGuid])
}

