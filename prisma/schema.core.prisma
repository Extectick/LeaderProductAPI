generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum ProfileStatus {
  PENDING
  ACTIVE
  BLOCKED
}

/*
 * Новые enum'ы для обращений
 */
enum AppealStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  DECLINED
  RESOLVED
}

enum AppealPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AttachmentType {
  IMAGE
  AUDIO
  FILE
}

enum AppealMessageType {
  USER
  SYSTEM
}

enum AppealLaborPaymentStatus {
  UNPAID
  PARTIAL
  PAID
  NOT_REQUIRED
}

enum AppealFinancialFunnelStatus {
  NOT_PAYABLE
  TO_PAY
  PARTIAL
  PAID
}

enum RouteStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum RouteEventType {
  MOVE
  STOP
}

enum AppPlatform {
  ANDROID
  IOS
}

enum AppUpdateEventType {
  CHECK
  PROMPT_SHOWN
  UPDATE_CLICK
  DISMISS
}

enum ServiceKind {
  LOCAL
  CLOUD
}

model AppUpdate {
  id                      Int         @id @default(autoincrement())
  platform                AppPlatform
  channel                 String      @default("prod")
  versionCode             Int
  versionName             String
  minSupportedVersionCode Int
  isMandatory             Boolean     @default(false)
  rolloutPercent          Int         @default(100)
  isActive                Boolean     @default(true)
  releaseNotes            String?
  storeUrl                String?
  apkKey                  String?
  fileSize                Int?
  checksum                String?
  checksumMd5             String?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  events                  AppUpdateEvent[]

  @@unique([platform, channel, versionCode])
  @@index([platform, channel, versionCode])
  @@index([platform, channel, minSupportedVersionCode])
}

model AppUpdateEvent {
  id          Int               @id @default(autoincrement())
  updateId    Int?
  update      AppUpdate?        @relation(fields: [updateId], references: [id])
  platform    AppPlatform
  channel     String
  versionCode Int
  versionName String?
  deviceId    String?
  eventType   AppUpdateEventType
  userId      Int?
  user        User?             @relation(fields: [userId], references: [id])
  createdAt   DateTime          @default(now())

  @@index([platform, channel, versionCode])
  @@index([deviceId])
  @@index([updateId])
}

model ClientProfile {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id])
  addressId Int?
  address   Address? @relation(fields: [addressId], references: [id])
  avatarUrl String?
  counterpartyId String?
  counterparty   Counterparty? @relation("ClientProfileCounterparty", fields: [counterpartyId], references: [id])

  activeAgreementId String?
  activeAgreement   ClientAgreement? @relation("ClientProfileActiveAgreement", fields: [activeAgreementId], references: [id])

  activeContractId String?
  activeContract   ClientContract? @relation("ClientProfileActiveContract", fields: [activeContractId], references: [id])

  activeWarehouseId String?
  activeWarehouse   Warehouse? @relation("ClientProfileActiveWarehouse", fields: [activeWarehouseId], references: [id])

  activePriceTypeId String?
  activePriceType   PriceType? @relation("ClientProfileActivePriceType", fields: [activePriceTypeId], references: [id])

  activeDeliveryAddressId String?
  activeDeliveryAddress   DeliveryAddress? @relation("ClientProfileActiveDeliveryAddress", fields: [activeDeliveryAddressId], references: [id])
  status    ProfileStatus @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([counterpartyId])
  @@index([activeAgreementId])
  @@index([activeContractId])
  @@index([activeWarehouseId])
  @@index([activePriceTypeId])
  @@index([activeDeliveryAddressId])
}

model SupplierProfile {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id])
  addressId Int?
  address   Address? @relation(fields: [addressId], references: [id])
  avatarUrl String?
  status    ProfileStatus @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmployeeProfile {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id])
  departmentId Int?
  department Department? @relation(fields: [departmentId], references: [id])
  appealLaborHourlyRate Decimal? @db.Decimal(8, 2)
  departmentRoles DepartmentRole[] @relation("EmployeeDepartmentRoles")
  avatarUrl String?
  status    ProfileStatus @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, departmentId, userId])
}

model Department {
  id    Int     @id @default(autoincrement())
  name  String  @unique
  appealPaymentRequired Boolean @default(true)
  appealLaborHourlyRate Decimal @default(1.0) @db.Decimal(8, 2)
  departmentRoles DepartmentRole[]
  employeeProfiles EmployeeProfile[]  // Добавлено обратное отношение
  serviceAccesses ServiceDepartmentAccess[]
  appealAnalyticsThresholds AppealAnalyticsThreshold[]

  // Новые связи с обращениями
  appealsFrom   Appeal[] @relation("AppealsFrom")
  appealsTo     Appeal[] @relation("AppealsTo")
}

enum ProfileType {
  CLIENT
  SUPPLIER
  EMPLOYEE
}

enum AuthProvider {
  LOCAL
  TELEGRAM
  MAX
  HYBRID
}

model User {
  id                 Int                 @id @default(autoincrement())
  email              String?             @unique
  passwordHash       String?
  isActive           Boolean             @default(false)
  roleId             Int 
  firstName          String?             // Имя
  lastName           String?             // Фамилия
  middleName         String?             // Отчество
  phone              BigInt?             @unique // Телефон пользователя в формате 79612231345
  phoneVerifiedAt    DateTime?
  avatarUrl          String?             // (устар.) Ссылка на аватар пользователя
  telegramId         BigInt?             @unique
  telegramUsername   String?
  telegramLinkedAt   DateTime?
  maxId              BigInt?             @unique
  maxUsername        String?
  maxLinkedAt        DateTime?
  authProvider       AuthProvider        @default(LOCAL)
  deletedAt          DateTime?           // Для soft delete
  currentProfileType ProfileType?        // Текущий активный профиль
  emailVerifications EmailVerification[]
  emailChangeSessions EmailChangeSession[]
  loginAttempts      LoginAttempt[]
  passwordResets     PasswordReset[]
  refreshTokens      RefreshToken[]
  role               Role                @relation(fields: [roleId], references: [id])
  departmentRoles    DepartmentRole[]
  auditLogs          AuditLog[]          @relation("UserAuditLogs")
  clientProfile      ClientProfile?
  supplierProfile    SupplierProfile?
  employeeProfile    EmployeeProfile?
  profileStatus      ProfileStatus       @default(PENDING)
  qrlist             QRList[]
  routes             UserRoute[]
  routePoints        RoutePoint[]
  createdOrders      Order[]             @relation("OrdersCreatedBy")
  orderEvents        OrderEvent[]        @relation("OrderEventsActor")
  lastSeenAt         DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  /*
   * Новые связи с обращениями
   */
  appealsCreated    Appeal[]            @relation("AppealsCreated")
  appealAssignees   AppealAssignee[]
  appealWatchers    AppealWatcher[]
  appealMessages    AppealMessage[]
  appealStatusHistory AppealStatusHistory[]
  deviceTokens      DeviceToken[]
  appealMessageReads AppealMessageRead[]
  appealLaborEntriesAssignee AppealLaborEntry[] @relation("AppealLaborEntryAssignee")
  appealLaborEntriesPaidBy AppealLaborEntry[] @relation("AppealLaborEntryPaidBy")
  appealLaborEntriesCreatedBy AppealLaborEntry[] @relation("AppealLaborEntryCreatedBy")
  appealLaborEntriesUpdatedBy AppealLaborEntry[] @relation("AppealLaborEntryUpdatedBy")
  appealLaborAuditAssignee AppealLaborAuditLog[]
  appealLaborAuditChangedBy AppealLaborAuditLog[] @relation("AppealLaborAuditChangedBy")
  updateEvents      AppUpdateEvent[]
  phoneVerificationSessions PhoneVerificationSession[]
  phoneMigrationReports     UserPhoneMigrationReport[]
  notificationSettings UserNotificationSettings?
  appealMutes          AppealMute[]

  @@index([email])
  @@index([currentProfileType, roleId, createdAt])
}

enum PhoneVerificationStatus {
  PENDING
  VERIFIED
  FAILED
  EXPIRED
  CANCELLED
}

enum PhoneVerificationProvider {
  TELEGRAM
  MAX
}

enum MessengerQrAuthProvider {
  TELEGRAM
  MAX
}

enum MessengerQrAuthStatus {
  PENDING
  AWAITING_CONTACT
  VERIFIED
  FAILED
  EXPIRED
  CANCELLED
  CONSUMED
}

enum EmailChangeSessionStatus {
  PENDING
  VERIFIED
  EXPIRED
  CANCELLED
  FAILED
}

model PhoneVerificationSession {
  id             String                  @id @default(cuid())
  userId         Int
  requestedPhone BigInt
  status         PhoneVerificationStatus @default(PENDING)
  provider       PhoneVerificationProvider @default(TELEGRAM)
  tokenHash      String                  @unique
  telegramUserId BigInt?
  chatId         BigInt?
  maxUserId      BigInt?
  maxChatId      BigInt?
  expiresAt      DateTime
  verifiedAt     DateTime?
  failureReason  String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([expiresAt])
  @@index([telegramUserId])
  @@index([maxUserId])
  @@index([maxChatId])
}

model MessengerQrAuthSession {
  id                String                  @id @default(cuid())
  provider          MessengerQrAuthProvider
  startTokenHash    String                  @unique
  clientTokenHash   String                  @unique
  status            MessengerQrAuthStatus   @default(PENDING)
  messengerUserId   BigInt?
  messengerChatId   BigInt?
  messengerUsername String?
  resolvedUserId    Int?
  failureReason     String?
  expiresAt         DateTime
  verifiedAt        DateTime?
  consumedAt        DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([provider, status, expiresAt])
  @@index([provider, messengerUserId, status])
}

model UserPhoneMigrationReport {
  id              Int      @id @default(autoincrement())
  userId          Int
  sourceField     String
  rawValue        String?
  normalizedValue String?
  reason          String
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([reason])
}

model EmailChangeSession {
  id            String                   @id @default(cuid())
  userId        Int
  currentEmail  String?
  requestedEmail String
  codeHash      String
  status        EmailChangeSessionStatus @default(PENDING)
  attemptsCount Int                      @default(0)
  expiresAt     DateTime
  verifiedAt    DateTime?
  lastSentAt    DateTime?
  failureReason String?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([requestedEmail])
  @@index([expiresAt])
}

model DepartmentRole {
  id           Int       @id @default(autoincrement())
  userId       Int
  roleId       Int
  departmentId Int

  user       User       @relation(fields: [userId], references: [id])
  role       Role       @relation(fields: [roleId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])

  employeeProfiles EmployeeProfile[] @relation("EmployeeDepartmentRoles") // Добавлено обратное отношение

  @@unique([userId, roleId, departmentId])
}

model Address {
  id        Int      @id @default(autoincrement())
  street    String
  city      String
  state     String?
  postalCode String?
  country   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientProfiles   ClientProfile[]
  supplierProfiles SupplierProfile[]
}

model Role {
  id            Int               @id @default(autoincrement())
  name          String            @unique
  displayName   String            @default("")
  permissions   RolePermissions[] @relation("RolePermissions")
  users         User[]
  departmentRoles DepartmentRole[]
  serviceAccesses ServiceRoleAccess[]

  parentRoleId  Int?              // Родительская роль для иерархии ролей
  parentRole    Role?             @relation("RoleHierarchy", fields: [parentRoleId], references: [id])
  childRoles    Role[]            @relation("RoleHierarchy")
}

model Permission {
  id          Int               @id @default(autoincrement())
  name        String            @unique
  displayName String            @default("")
  description String            @default("")
  groupId     Int?
  group       PermissionGroup?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  roles       RolePermissions[] @relation("RolePermissions")

  @@index([groupId])
}

model PermissionGroup {
  id          Int          @id @default(autoincrement())
  key         String       @unique
  displayName String
  description String       @default("")
  sortOrder   Int          @default(100)
  isSystem    Boolean      @default(false)
  serviceId   Int?         @unique
  service     Service?     @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  permissions Permission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([sortOrder])
}

model RolePermissions {
  roleId       Int
  permissionId Int
  permission   Permission @relation("RolePermissions", fields: [permissionId], references: [id])
  role         Role       @relation("RolePermissions", fields: [roleId], references: [id])

  @@id([roleId, permissionId])
}

model Service {
  id              Int                      @id @default(autoincrement())
  key             String                   @unique
  name            String
  kind            ServiceKind              @default(CLOUD)
  route           String?
  icon            String?
  description     String?
  gradientStart   String?
  gradientEnd     String?
  isActive        Boolean                  @default(true)
  defaultVisible  Boolean                  @default(true)
  defaultEnabled  Boolean                  @default(true)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  roleAccess      ServiceRoleAccess[]
  departmentAccess ServiceDepartmentAccess[]
  permissionGroup PermissionGroup?
}

model ServiceRoleAccess {
  id        Int      @id @default(autoincrement())
  serviceId Int
  roleId    Int
  visible   Boolean?
  enabled   Boolean?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([serviceId, roleId])
  @@index([roleId])
}

model ServiceDepartmentAccess {
  id           Int      @id @default(autoincrement())
  serviceId    Int
  departmentId Int
  visible      Boolean?
  enabled      Boolean?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  service    Service    @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([serviceId, departmentId])
  @@index([departmentId])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id])
}

model LoginAttempt {
  id        Int      @id @default(autoincrement())
  userId    Int
  success   Boolean
  ip        String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model EmailVerification {
  id           Int      @id @default(autoincrement())
  userId       Int
  code         String
  expiresAt    DateTime
  used         Boolean  @default(false)
  attemptsCount Int      @default(0)
  lastSentAt   DateTime?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  userId    Int
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

enum ActionType {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PASSWORD_RESET
  EMAIL_VERIFICATION
  OTHER
}

model AuditLog {
  id         Int        @id @default(autoincrement())
  userId     Int?
  action     ActionType
  targetType String?
  targetId   Int?
  timestamp  DateTime   @default(now())
  details    String?

  user       User?      @relation("UserAuditLogs", fields: [userId], references: [id])
}

model UserRoute {
  id        Int          @id @default(autoincrement())
  userId    Int
  user      User         @relation(fields: [userId], references: [id])
  status    RouteStatus  @default(ACTIVE)
  startedAt DateTime     @default(now())
  endedAt   DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  points    RoutePoint[]

  @@index([userId, startedAt])
}

model RoutePoint {
  id                  Int             @id @default(autoincrement())
  routeId             Int
  route               UserRoute       @relation(fields: [routeId], references: [id])
  userId              Int
  user                User            @relation(fields: [userId], references: [id])
  latitude            Float
  longitude           Float
  recordedAt          DateTime
  eventType           RouteEventType  @default(MOVE)
  accuracy            Float?
  speed               Float?
  heading             Float?
  stayDurationSeconds Int?
  sequence            Int?
  createdAt           DateTime        @default(now())

  @@index([userId, recordedAt])
  @@index([routeId, recordedAt])
}

enum QRStatus {
  ACTIVE
  PAUSED
  DELETED
}

enum QRType {
  PHONE
  LINK
  EMAIL
  TEXT
  WHATSAPP
  CONTACT
  TELEGRAM
}

model QRList {
  id          String      @id
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  status      QRStatus    @default(ACTIVE)
  createdBy   User        @relation(fields: [createdById], references: [id])
  createdById Int
  qrData      String
  qrType      QRType      @default(TEXT)
  description String?
  analytics   QRAnalytic[]
}

model QRAnalytic {
  id           Int       @id @default(autoincrement())
  ip           String?
  location     String?
  browser      String?
  device       String?
  scanDuration Int?      // Время в миллисекундах
  createdAt    DateTime  @default(now())
  qrList       QRList    @relation(fields: [qrListId], references: [id])
  qrListId     String
}

/*
 * Новые модели для системы обращений
 */
model Appeal {
  id               Int            @id @default(autoincrement())
  number           Int            @unique
  fromDepartmentId Int?
  toDepartmentId   Int
  createdById      Int
  status           AppealStatus   @default(OPEN)
  priority         AppealPriority @default(MEDIUM)
  deadline         DateTime?
  title            String?
  laborNotRequired Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  fromDepartment   Department?    @relation("AppealsFrom", fields: [fromDepartmentId], references: [id])
  toDepartment     Department     @relation("AppealsTo", fields: [toDepartmentId], references: [id])
  createdBy        User           @relation("AppealsCreated", fields: [createdById], references: [id])
  assignees        AppealAssignee[]
  watchers         AppealWatcher[]
  messages         AppealMessage[]
  statusHistory    AppealStatusHistory[]
  laborEntries     AppealLaborEntry[]
  laborAuditLogs   AppealLaborAuditLog[]
  mutes            AppealMute[]
}

model AppealAssignee {
  id       Int   @id @default(autoincrement())
  appealId Int
  userId   Int

  appeal   Appeal @relation(fields: [appealId], references: [id])
  user     User   @relation(fields: [userId], references: [id])

  @@unique([appealId, userId])
}

model AppealWatcher {
  id       Int   @id @default(autoincrement())
  appealId Int
  userId   Int

  appeal   Appeal @relation(fields: [appealId], references: [id])
  user     User   @relation(fields: [userId], references: [id])

  @@unique([appealId, userId])
}

model AppealStatusHistory {
  id         Int          @id @default(autoincrement())
  appealId   Int
  oldStatus  AppealStatus
  newStatus  AppealStatus
  changedById Int
  changedAt  DateTime      @default(now())

  appeal     Appeal        @relation(fields: [appealId], references: [id])
  changedBy  User          @relation(fields: [changedById], references: [id])
}

model AppealMessage {
  id        Int      @id @default(autoincrement())
  appealId  Int
  senderId  Int
  text      String?
  type      AppealMessageType @default(USER)
  systemEvent Json?
  editedAt  DateTime?
  deleted   Boolean  @default(false)
  createdAt DateTime @default(now())

  appeal    Appeal   @relation(fields: [appealId], references: [id])
  sender    User     @relation(fields: [senderId], references: [id])
  attachments AppealAttachment[]
  reads     AppealMessageRead[]

  @@index([appealId, createdAt, id])
}

model AppealAttachment {
  id         Int           @id @default(autoincrement())
  messageId  Int
  fileUrl    String
  fileName   String
  fileType   AttachmentType
  createdAt  DateTime       @default(now())

  message    AppealMessage  @relation(fields: [messageId], references: [id])
}

model AppealMessageRead {
  id        Int            @id @default(autoincrement())
  message   AppealMessage  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  messageId Int
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  readAt    DateTime       @default(now())

  @@unique([messageId, userId])
}

model AppealLaborEntry {
  id             Int                      @id @default(autoincrement())
  appealId       Int
  assigneeUserId Int
  hours          Decimal                  @default(0.0) @db.Decimal(8, 2)
  paidHours      Decimal                  @default(0.0) @db.Decimal(8, 2)
  effectiveHourlyRateRub Decimal          @default(0.0) @db.Decimal(8, 2)
  paymentStatus  AppealLaborPaymentStatus @default(UNPAID)
  paidAt         DateTime?
  paidById       Int?
  createdById    Int
  updatedById    Int
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  appeal         Appeal @relation(fields: [appealId], references: [id], onDelete: Cascade)
  assignee       User   @relation("AppealLaborEntryAssignee", fields: [assigneeUserId], references: [id], onDelete: Cascade)
  paidBy         User?  @relation("AppealLaborEntryPaidBy", fields: [paidById], references: [id], onDelete: SetNull)
  createdBy      User   @relation("AppealLaborEntryCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy      User   @relation("AppealLaborEntryUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  @@unique([appealId, assigneeUserId])
  @@index([assigneeUserId, paymentStatus])
  @@index([appealId, paymentStatus])
}

model AppealLaborAuditLog {
  id               Int                      @id @default(autoincrement())
  appealId         Int
  assigneeUserId   Int
  changedById      Int
  oldHours         Decimal?                 @db.Decimal(8, 2)
  newHours         Decimal                  @db.Decimal(8, 2)
  oldPaidHours     Decimal?                 @db.Decimal(8, 2)
  newPaidHours     Decimal?                 @db.Decimal(8, 2)
  oldPaymentStatus AppealLaborPaymentStatus?
  newPaymentStatus AppealLaborPaymentStatus
  changedAt        DateTime                 @default(now())

  appeal           Appeal @relation(fields: [appealId], references: [id], onDelete: Cascade)
  assignee         User   @relation(fields: [assigneeUserId], references: [id], onDelete: Cascade)
  changedBy        User   @relation("AppealLaborAuditChangedBy", fields: [changedById], references: [id], onDelete: Restrict)

  @@index([appealId, changedAt])
  @@index([assigneeUserId, changedAt])
}

model AppealAnalyticsThreshold {
  id                   Int      @id @default(autoincrement())
  departmentId         Int
  openTooLongHours     Int      @default(24)
  resolvedTooLongHours Int      @default(24)
  laborMissingDays     Int      @default(3)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  department           Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([departmentId])
}

model DeviceToken {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  token     String   @unique
  platform  String?
  createdAt DateTime @default(now())
}

model UserNotificationSettings {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Глобальные переключатели (экран профиля)
  inAppNotificationsEnabled    Boolean @default(true)
  telegramNotificationsEnabled Boolean @default(true)
  maxNotificationsEnabled      Boolean @default(true)

  // Гранулярные каналы
  pushNewMessage          Boolean @default(true)
  pushStatusChanged       Boolean @default(true)
  pushDeadlineChanged     Boolean @default(true)
  telegramNewAppeal       Boolean @default(true)
  telegramStatusChanged   Boolean @default(true)
  telegramDeadlineChanged Boolean @default(true)
  telegramUnreadReminder  Boolean @default(true)
  telegramClosureReminder Boolean @default(true)
  telegramNewMessage      Boolean @default(true)
  maxNewAppeal            Boolean @default(true)
  maxStatusChanged        Boolean @default(true)
  maxDeadlineChanged      Boolean @default(true)
  maxUnreadReminder       Boolean @default(true)
  maxClosureReminder      Boolean @default(true)
  maxNewMessage           Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model AppealMute {
  id       Int    @id @default(autoincrement())
  userId   Int
  appealId Int
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  appeal   Appeal @relation(fields: [appealId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, appealId])
  @@index([appealId])
}


