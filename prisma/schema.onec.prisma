// ==========================
// 1C Integration models
// ==========================

enum OrderStatus {
  DRAFT
  QUEUED
  SENT_TO_1C
  CONFIRMED
  PARTIAL
  REJECTED
  CANCELLED
}

enum OrderSyncState {
  DRAFT
  QUEUED
  SYNCED
  CONFLICT
  ERROR
  CANCEL_REQUESTED
}

enum OrderSource {
  MARKETPLACE_CLIENT
  MANAGER_APP
}

enum OrderEventSource {
  APP_MANAGER
  APP_CANCEL_REQUEST
  ONEC_ACK
  ONEC_IMPORT
  ONEC_EDIT
  ONEC_POST
  SYSTEM
}

enum ClientOrderDeliveryDateMode {
  NEXT_DAY
  OFFSET_DAYS
  FIXED_DATE
}

model Counterparty {
  id                       String   @id @default(cuid())
  guid                     String   @unique
  name                     String
  fullName                 String?
  inn                      String?
  kpp                      String?
  phone                    String?
  email                    String?
  dataVersion              String?
  isSeparateSubdivision    Boolean?
  legalEntityType          String?
  legalOrIndividualType    String?
  registrationCountryGuid  String?
  headCounterpartyGuid     String?
  additionalInfo           String?
  partnerGuid              String?
  vatByRates4And2          Boolean?
  okpoCode                 String?
  registrationNumber       String?
  taxNumber                String?
  internationalName        String?
  isPredefined             Boolean?
  predefinedDataName       String?
  isActive                 Boolean  @default(true)
  defaultAgreementId       String?
  defaultContractId        String?
  defaultWarehouseId       String?
  defaultDeliveryAddressId String?

  sourceUpdatedAt DateTime?
  lastSyncedAt    DateTime?

  contracts                   ClientContract[]
  agreements                  ClientAgreement[]
  addresses                   DeliveryAddress[]
  specialPrices               SpecialPrice[]
  orders                      Order[]
  clientProfiles              ClientProfile[] @relation("ClientProfileCounterparty")
  defaultAgreement            ClientAgreement? @relation("CounterpartyDefaultAgreement", fields: [defaultAgreementId], references: [id])
  defaultContract             ClientContract? @relation("CounterpartyDefaultContract", fields: [defaultContractId], references: [id])
  defaultWarehouse            Warehouse? @relation("CounterpartyDefaultWarehouse", fields: [defaultWarehouseId], references: [id])
  defaultDeliveryAddress      DeliveryAddress? @relation("CounterpartyDefaultDeliveryAddress", fields: [defaultDeliveryAddressId], references: [id])
  clientOrderRememberedDefaults ClientOrderUserCounterpartyDefaults[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([sourceUpdatedAt])
  @@index([defaultAgreementId])
  @@index([defaultContractId])
  @@index([defaultWarehouseId])
  @@index([defaultDeliveryAddressId])
}

model DeliveryAddress {
  id             String   @id @default(cuid())
  guid           String?  @unique
  counterpartyId String

  name           String?
  fullAddress    String
  city           String?
  street         String?
  house          String?
  building       String?
  apartment      String?
  postcode       String?

  isDefault      Boolean  @default(false)
  isActive       Boolean  @default(true)

  sourceUpdatedAt DateTime?
  lastSyncedAt    DateTime?

  counterparty               Counterparty @relation(fields: [counterpartyId], references: [id])
  orders                     Order[]
  activeForProfiles          ClientProfile[] @relation("ClientProfileActiveDeliveryAddress")
  defaultForCounterparties   Counterparty[] @relation("CounterpartyDefaultDeliveryAddress")
  clientOrderRememberedDefaults ClientOrderUserCounterpartyDefaults[] @relation("ClientOrderUserDefaultDeliveryAddress")

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([counterpartyId])
  @@index([isActive])
  @@index([sourceUpdatedAt])
}

model ProductGroup {
  id        String   @id @default(cuid())
  guid      String   @unique
  name      String
  code      String?
  isActive  Boolean  @default(true)

  sourceUpdatedAt DateTime?
  lastSyncedAt    DateTime?

  parentId  String?
  parent    ProductGroup? @relation("ProductGroupHierarchy", fields: [parentId], references: [id])
  children  ProductGroup[] @relation("ProductGroupHierarchy")

  products  Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([isActive])
  @@index([sourceUpdatedAt])
}

model Unit {
  id       String   @id @default(cuid())
  guid     String?  @unique
  name     String
  code     String?
  symbol   String?

  sourceUpdatedAt DateTime?
  lastSyncedAt    DateTime?

  products Product[]       @relation("Product_baseUnit")
  packages ProductPackage[]
  orderItems OrderItem[]   @relation("OrderItem_unit")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sourceUpdatedAt])
}

model Product {
  id           String   @id @default(cuid())
  guid         String   @unique
  name         String
  code         String?
  article      String?
  sku          String?
  groupId      String?
  isWeight     Boolean  @default(false)
  isService    Boolean  @default(false)
  isActive     Boolean  @default(true)

  sourceUpdatedAt DateTime?
  lastSyncedAt    DateTime?

  group        ProductGroup? @relation(fields: [groupId], references: [id])

  baseUnitId   String?
  baseUnit     Unit?    @relation("Product_baseUnit", fields: [baseUnitId], references: [id])

  packages     ProductPackage[]
  stocks       StockBalance[]
  prices       ProductPrice[]
  specialPrices SpecialPrice[]
  orderItems   OrderItem[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([groupId])
  @@index([isActive])
  @@index([sourceUpdatedAt])
  @@index([sku])
  @@index([article])
}

model ProductPackage {
  id         String   @id @default(cuid())
  guid       String?  @unique
  productId  String
  unitId     String
  name       String
  multiplier Decimal   @db.Decimal(18, 4)
  barcode    String?
  isDefault  Boolean   @default(false)
  sortOrder  Int       @default(0)

  sourceUpdatedAt DateTime?
  lastSyncedAt    DateTime?

  product    Product @relation(fields: [productId], references: [id])
  unit       Unit    @relation(fields: [unitId], references: [id])

  orderItems OrderItem[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([productId])
  @@index([barcode])
  @@index([sourceUpdatedAt])
}

model Warehouse {
  id        String   @id @default(cuid())
  guid      String   @unique
  name      String
  code      String?
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(false)
  isPickup  Boolean  @default(false)
  address   String?

  sourceUpdatedAt DateTime?
  lastSyncedAt    DateTime?

  stocks                     StockBalance[]
  agreements                 ClientAgreement[]
  orders                     Order[]
  activeForProfiles          ClientProfile[] @relation("ClientProfileActiveWarehouse")
  defaultForCounterparties   Counterparty[] @relation("CounterpartyDefaultWarehouse")
  clientOrderRememberedDefaults ClientOrderUserCounterpartyDefaults[] @relation("ClientOrderUserDefaultWarehouse")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([isDefault])
  @@index([sourceUpdatedAt])
}

model Organization {
  id        String   @id @default(cuid())
  guid      String   @unique
  name      String
  code      String?
  isActive  Boolean  @default(true)

  sourceUpdatedAt DateTime?
  lastSyncedAt    DateTime?

  stocks                     StockBalance[]
  contracts                  ClientContract[]
  agreements                 ClientAgreement[]
  orders                     Order[]
  clientOrderPreferredBy     ClientOrderUserSettings[] @relation("ClientOrderPreferredOrganization")
  clientOrderRememberedDefaults ClientOrderUserCounterpartyDefaults[] @relation("ClientOrderRememberedDefaultsOrganization")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([sourceUpdatedAt])
}

model StockBalance {
  id                   String   @id @default(cuid())
  syncKey              String   @unique
  productId            String
  warehouseId          String
  organizationId       String?
  quantity             Decimal  @db.Decimal(18, 3)
  reserved             Decimal? @db.Decimal(18, 3)
  inStock              Decimal? @db.Decimal(18, 3)
  shipping             Decimal? @db.Decimal(18, 3)
  clientReserved       Decimal? @db.Decimal(18, 3)
  managerReserved      Decimal? @db.Decimal(18, 3)
  available            Decimal? @db.Decimal(18, 3)
  updatedAt            DateTime
  seriesGuid           String?
  seriesNumber         String?
  seriesProductionDate DateTime?
  seriesExpiresAt      DateTime?

  sourceUpdatedAt DateTime?
  lastSyncedAt    DateTime?

  product      Product      @relation(fields: [productId], references: [id])
  warehouse    Warehouse    @relation(fields: [warehouseId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([warehouseId])
  @@index([seriesGuid])
  @@index([updatedAt])
  @@index([sourceUpdatedAt])
}

model ClientContract {
  id             String   @id @default(cuid())
  guid           String   @unique
  counterpartyId String
  organizationId String?
  dataVersion    String?
  name           String?
  printName      String?
  number         String
  date           DateTime
  validFrom      DateTime?
  validTo        DateTime?
  partnerGuid    String?
  bankAccountGuid String?
  counterpartyBankAccountGuid String?
  contactPersonGuid String?
  departmentGuid String?
  managerGuid    String?
  cashFlowItemGuid String?
  businessOperation String?
  financialAccountingGroupGuid String?
  activityDirectionGuid String?
  currency       String?
  currencyGuid   String?
  status         String?
  contractType   String?
  purpose        String?
  isAgreed       Boolean?
  hasPaymentTerm Boolean?
  paymentTermDays Int?
  settlementProcedure String?
  limitDebtAmount Boolean?
  amount         Decimal? @db.Decimal(18, 2)
  allowedDebtAmount Decimal? @db.Decimal(18, 2)
  forbidOverdueDebt Boolean?
  vatTaxation    String?
  vatRate        String?
  vatDefinedInDocument Boolean?
  deliveryMethod String?
  carrierPartnerGuid String?
  deliveryZoneGuid String?
  deliveryTimeFrom String?
  deliveryTimeTo String?
  deliveryAddress String?
  deliveryAddressFields String?
  additionalDeliveryInfo String?
  isActive       Boolean  @default(true)
  comment        String?

  sourceUpdatedAt DateTime?
  lastSyncedAt    DateTime?

  counterparty               Counterparty   @relation(fields: [counterpartyId], references: [id])
  organization               Organization?  @relation(fields: [organizationId], references: [id])
  agreements                 ClientAgreement[]
  orders                     Order[]
  activeForProfiles          ClientProfile[] @relation("ClientProfileActiveContract")
  defaultForCounterparties   Counterparty[] @relation("CounterpartyDefaultContract")
  clientOrderRememberedDefaults ClientOrderUserCounterpartyDefaults[] @relation("ClientOrderUserDefaultContract")

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([counterpartyId])
  @@index([organizationId])
  @@index([status])
  @@index([isActive])
  @@index([sourceUpdatedAt])
}

model PriceType {
  id           String   @id @default(cuid())
  guid         String   @unique
  name         String
  code         String?
  isActive     Boolean  @default(true)

  sourceUpdatedAt DateTime?
  lastSyncedAt    DateTime?

  agreements    ClientAgreement[]
  orderItems    OrderItem[]
  productPrices ProductPrice[]
  specialPrices SpecialPrice[]
  activeForProfiles ClientProfile[] @relation("ClientProfileActivePriceType")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
  @@index([sourceUpdatedAt])
}

model ClientAgreement {
  id              String   @id @default(cuid())
  guid            String   @unique
  name            String
  number          String?
  date            DateTime?
  counterpartyId  String?
  organizationId  String?
  contractId      String?
  priceTypeId     String?
  warehouseId     String?
  currency        String?
  dataVersion     String?
  partnerGuid     String?
  partnerSegmentGuid String?
  paymentScheduleGuid String?
  documentAmount  Decimal? @db.Decimal(18, 2)
  isTemplate      Boolean?
  deliveryTerm    String?
  priceIncludesVat Boolean?
  usedBySalesRepresentatives Boolean?
  parentAgreementGuid String?
  nomenclatureSegmentGuid String?
  validFrom       DateTime?
  validTo         DateTime?
  comment         String?
  isRegular       Boolean?
  period          String?
  periodCount     Int?
  status          String?
  isAgreed        Boolean?
  managerGuid     String?
  businessOperation String?
  manualDiscountPercent Decimal? @db.Decimal(5, 2)
  manualMarkupPercent Decimal? @db.Decimal(5, 2)
  availableForExternalUsers Boolean?
  usesCounterpartyContracts Boolean?
  limitManualDiscounts Boolean?
  paymentForm     String?
  contactPersonGuid String?
  settlementProcedure String?
  priceCalculationVariant String?
  minOrderAmount  Decimal? @db.Decimal(18, 2)
  orderFrequency  String?
  individualPriceTypeGuid String?
  settlementCurrency String?
  paymentInCurrency Boolean?
  financialAccountingGroupGuid String?
  cashFlowItemGuid String?
  activityDirectionGuid String?

  isActive        Boolean  @default(true)

  sourceUpdatedAt DateTime?
  lastSyncedAt    DateTime?

  counterparty    Counterparty?   @relation(fields: [counterpartyId], references: [id])
  organization    Organization?   @relation(fields: [organizationId], references: [id])
  contract        ClientContract? @relation(fields: [contractId], references: [id])
  warehouse       Warehouse?      @relation(fields: [warehouseId], references: [id])
  priceType       PriceType?      @relation(fields: [priceTypeId], references: [id])

  specialPrices               SpecialPrice[]
  orders                      Order[]
  activeForProfiles           ClientProfile[] @relation("ClientProfileActiveAgreement")
  defaultForCounterparties    Counterparty[] @relation("CounterpartyDefaultAgreement")
  clientOrderRememberedDefaults ClientOrderUserCounterpartyDefaults[] @relation("ClientOrderUserDefaultAgreement")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([counterpartyId])
  @@index([organizationId])
  @@index([contractId])
  @@index([warehouseId])
  @@index([priceTypeId])
  @@index([status])
  @@index([isActive])
  @@index([sourceUpdatedAt])
}

model ProductPrice {
  id          String   @id @default(cuid())
  guid        String?  @unique
  productId   String
  priceTypeId String?

  price       Decimal  @db.Decimal(18, 4)
  currency    String?
  startDate   DateTime?
  endDate     DateTime?
  minQty      Decimal? @db.Decimal(18, 3)
  isActive    Boolean  @default(true)

  sourceUpdatedAt DateTime?
  lastSyncedAt    DateTime?

  product     Product   @relation(fields: [productId], references: [id])
  priceType   PriceType? @relation(fields: [priceTypeId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId])
  @@index([priceTypeId])
  @@index([isActive])
  @@index([sourceUpdatedAt])
  @@unique([productId, priceTypeId, startDate])
}

model SpecialPrice {
  id              String   @id @default(cuid())
  guid            String?  @unique

  productId       String
  counterpartyId  String?
  agreementId     String?
  priceTypeId     String?

  price           Decimal  @db.Decimal(18, 4)
  currency        String?
  startDate       DateTime?
  endDate         DateTime?
  minQty          Decimal? @db.Decimal(18, 3)
  isActive        Boolean  @default(true)

  sourceUpdatedAt DateTime?
  lastSyncedAt    DateTime?

  product         Product        @relation(fields: [productId], references: [id])
  counterparty    Counterparty?  @relation(fields: [counterpartyId], references: [id])
  agreement       ClientAgreement? @relation(fields: [agreementId], references: [id])
  priceType       PriceType?     @relation(fields: [priceTypeId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([productId])
  @@index([productId, counterpartyId])
  @@index([productId, agreementId])
  @@index([productId, priceTypeId])
  @@index([isActive])
  @@index([sourceUpdatedAt])
  @@unique([productId, counterpartyId, agreementId, priceTypeId, startDate])
}

model Order {
  id                String       @id @default(cuid())
  guid              String?      @unique
  number1c          String?
  date1c            DateTime?
  source            OrderSource  @default(MARKETPLACE_CLIENT)
  revision          Int          @default(1)
  syncState         OrderSyncState @default(DRAFT)

  counterpartyId    String
  agreementId       String?
  contractId        String?
  warehouseId       String?
  deliveryAddressId String?
  organizationId    String?
  createdByUserId   Int?

  status            OrderStatus @default(DRAFT)
  comment           String?
  deliveryDate      DateTime?
  totalAmount       Decimal?    @db.Decimal(18, 2)
  currency          String?
  generalDiscountPercent Decimal? @db.Decimal(5, 2)
  generalDiscountAmount  Decimal? @db.Decimal(18, 2)

  queuedAt          DateTime?
  sentTo1cAt        DateTime?
  lastStatusSyncAt  DateTime?
  exportAttempts    Int        @default(0)
  lastExportError   String?
  isPostedIn1c      Boolean    @default(false)
  postedAt1c        DateTime?
  cancelRequestedAt DateTime?
  cancelReason      String?
  last1cError       String?
  last1cSnapshot    Json?

  sourceUpdatedAt   DateTime?
  lastSyncedAt      DateTime?

  counterparty      Counterparty    @relation(fields: [counterpartyId], references: [id])
  agreement         ClientAgreement? @relation(fields: [agreementId], references: [id])
  contract          ClientContract? @relation(fields: [contractId], references: [id])
  warehouse         Warehouse?      @relation(fields: [warehouseId], references: [id])
  deliveryAddress   DeliveryAddress? @relation(fields: [deliveryAddressId], references: [id])
  organization      Organization?   @relation(fields: [organizationId], references: [id])
  createdByUser     User?           @relation("OrdersCreatedBy", fields: [createdByUserId], references: [id])

  items             OrderItem[]
  events            OrderEvent[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([counterpartyId])
  @@index([agreementId])
  @@index([contractId])
  @@index([warehouseId])
  @@index([organizationId])
  @@index([createdByUserId])
  @@index([status])
  @@index([source])
  @@index([syncState])
  @@index([revision])
  @@index([queuedAt])
  @@index([sentTo1cAt])
  @@index([sourceUpdatedAt])
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  productId       String
  packageId       String?
  unitId          String?
  priceTypeId     String?

  quantity        Decimal  @db.Decimal(18, 3)
  quantityBase    Decimal? @db.Decimal(18, 3)
  basePrice       Decimal? @db.Decimal(18, 4)
  price           Decimal  @db.Decimal(18, 4)
  isManualPrice   Boolean  @default(false)
  manualPrice     Decimal? @db.Decimal(18, 4)
  priceSource     String?
  discountPercent Decimal? @db.Decimal(5, 2)
  appliedDiscountPercent Decimal? @db.Decimal(5, 2)
  lineAmount      Decimal? @db.Decimal(18, 2)
  comment         String?

  sourceUpdatedAt DateTime?
  lastSyncedAt    DateTime?

  order           Order          @relation(fields: [orderId], references: [id])
  product         Product        @relation(fields: [productId], references: [id])
  package         ProductPackage? @relation(fields: [packageId], references: [id])
  unit            Unit?          @relation("OrderItem_unit", fields: [unitId], references: [id])
  priceType       PriceType?      @relation(fields: [priceTypeId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
  @@index([priceTypeId])
  @@index([sourceUpdatedAt])
}

model OrderEvent {
  id          String           @id @default(cuid())
  orderId      String
  revision     Int
  source       OrderEventSource
  eventType    String
  payload      Json
  actorUserId  Int?
  note         String?
  createdAt    DateTime         @default(now())

  order        Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actorUser    User?            @relation("OrderEventsActor", fields: [actorUserId], references: [id])

  @@index([orderId])
  @@index([orderId, revision])
  @@index([source])
  @@index([actorUserId])
}

model ClientOrderUserSettings {
  id                      Int                         @id @default(autoincrement())
  userId                  Int                         @unique
  preferredOrganizationId String?
  deliveryDateMode        ClientOrderDeliveryDateMode @default(NEXT_DAY)
  deliveryDateOffsetDays  Int                         @default(1)
  fixedDeliveryDate       DateTime?
  user                    User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferredOrganization   Organization?               @relation("ClientOrderPreferredOrganization", fields: [preferredOrganizationId], references: [id], onDelete: SetNull)
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt

  @@index([preferredOrganizationId])
}

model ClientOrderUserCounterpartyDefaults {
  id                Int              @id @default(autoincrement())
  userId            Int
  organizationId    String
  counterpartyId    String
  agreementId       String?
  contractId        String?
  warehouseId       String?
  deliveryAddressId String?
  lastUsedAt        DateTime         @default(now())
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization      Organization     @relation("ClientOrderRememberedDefaultsOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  counterparty      Counterparty     @relation(fields: [counterpartyId], references: [id], onDelete: Cascade)
  agreement         ClientAgreement? @relation("ClientOrderUserDefaultAgreement", fields: [agreementId], references: [id], onDelete: SetNull)
  contract          ClientContract?  @relation("ClientOrderUserDefaultContract", fields: [contractId], references: [id], onDelete: SetNull)
  warehouse         Warehouse?       @relation("ClientOrderUserDefaultWarehouse", fields: [warehouseId], references: [id], onDelete: SetNull)
  deliveryAddress   DeliveryAddress? @relation("ClientOrderUserDefaultDeliveryAddress", fields: [deliveryAddressId], references: [id], onDelete: SetNull)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([userId, organizationId, counterpartyId])
  @@index([userId])
  @@index([organizationId])
  @@index([counterpartyId])
  @@index([agreementId])
  @@index([contractId])
  @@index([warehouseId])
  @@index([deliveryAddressId])
}
